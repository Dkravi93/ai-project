# ==================== LLM & API Keys ====================
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# ==================== Vector Database (Qdrant) ====================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=documents
QDRANT_TIMEOUT_SECONDS=3

# ==================== FastAPI Configuration ====================
API_HOST=0.0.0.0
API_PORT=8000
UI_API_BASE_URL=http://localhost:8000
API_KEY=your_api_key_for_auth_header
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ==================== Database (PostgreSQL) ====================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentops_hub

# ==================== Observability & Monitoring ====================
MLFLOW_TRACKING_URI=http://localhost:5000
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=agentops-hub
PROMETHEUS_SCRAPE_PORT=8001

# ==================== Embedding Model ====================
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
EMBEDDING_CACHE_DIR=./models

# ==================== Guardrails Configuration ====================
PRESIDIO_OPERATORS_ENABLED=true
DETOXIFY_BATCH_SIZE=32
RAGAS_THRESHOLD=0.7
PII_THRESHOLD=0.5
TOXICITY_THRESHOLD=0.6
SEVERE_TOXICITY_THRESHOLD=0.8
PROMPT_INJECTION_THRESHOLD=0.7
TOKEN_HARD_LIMIT=8000

# ==================== Coder Sandbox ====================
SANDBOX_TIMEOUT_SECONDS=10
SANDBOX_MAX_ATTEMPTS=3

# ==================== Deployment ====================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
